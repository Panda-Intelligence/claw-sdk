{
  "name": "@panda-ai/claw-sdk",
  "version": "0.1.0",
  "description": "Pure TypeScript SDK for standard OpenClaw gateway API calls",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.mjs"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Panda-Intelligence/claw-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Panda-Intelligence/claw-sdk/issues"
  },
  "homepage": "https://github.com/Panda-Intelligence/claw-sdk#readme",
  "engines": {
    "node": ">=18.17"
  },
  "sideEffects": false,
  "packageManager": "pnpm@10.27.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --watch",
    "test": "vitest run",
    "test:real": "bash -lc 'if [ ! -f .env.real ]; then echo \"Missing .env.real. Run: cp .env.real.example .env.real\"; exit 1; fi; set -a; . ./.env.real; set +a; CLAW_REAL_REQUIRED=1 vitest run tests/real-gateway.test.ts'",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "openclaw",
    "nanoclaw",
    "ai-agent",
    "claw",
    "llm",
    "sdk"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.0.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
